generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// 🔐 USER (AUTH CORE)
//
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  role         Role
  refreshToken String?

  admin        Admin?
  teacher      Teacher?
  student      Student?
  parent       Parent?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

//
// 👑 ADMIN
//
model Admin {
  id          Int   @id @default(autoincrement())
  userId      Int   @unique

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  school_name String
}

//
// 👨‍🏫 TEACHER
//
model Teacher {
  id       Int   @id @default(autoincrement())
  userId   Int   @unique

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone    String?
  sessions ClassSession[]
}

//
// 🎓 STUDENT
//
model Student {
  id            Int   @id @default(autoincrement())
  userId        Int   @unique

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  date_of_birth DateTime?
  gender        String?
  address       String?

  parents       StudentParent[]
  attendances   Attendance[]
  grades        Grade[]
  payments      FeePayment[]
}

//
// 👪 PARENT
//
model Parent {
  id       Int   @id @default(autoincrement())
  userId   Int   @unique

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone    String?
  students StudentParent[]
}

//
// 🔗 STUDENT ↔ PARENT (MANY TO MANY)
//
model StudentParent {
  studentId Int
  parentId  Int

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
}

//
// 📚 SUBJECT
//
model Subject {
  id       Int   @id @default(autoincrement())
  name     String
  code     String @unique

  sessions ClassSession[]
  grades   Grade[]
}

//
// 🏫 CLASS
//
model Class {
  id       Int   @id @default(autoincrement())
  name     String

  sessions ClassSession[]
}

//
// 📅 CLASS SESSION
//
model ClassSession {
  id           Int   @id @default(autoincrement())

  teacherId    Int?
  subjectId    Int?
  classId      Int?

  teacher      Teacher? @relation(fields: [teacherId], references: [id])
  subject      Subject? @relation(fields: [subjectId], references: [id])
  class        Class?   @relation(fields: [classId], references: [id])

  term         String?
  sessionYear  String?

  attendances  Attendance[]
  grades       Grade[]
}

//
// 🧾 ATTENDANCE
//
model Attendance {
  id          Int   @id @default(autoincrement())

  studentId   Int
  sessionId   Int

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session     ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  date        DateTime
  status      String
}

//
// 🧮 GRADE
//
model Grade {
  id            Int   @id @default(autoincrement())

  studentId     Int
  sessionId     Int
  subjectId     Int

  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session       ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subject       Subject      @relation(fields: [subjectId], references: [id])

  score         Decimal? @db.Decimal(5, 2)
  gradeLetter   String?
}

//
// 💰 FEE PAYMENT
//
model FeePayment {
  id           Int   @id @default(autoincrement())

  studentId    Int
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  amount       Decimal @db.Decimal(10, 2)
  paymentDate  DateTime?
  term         String?
  sessionYear  String?
}